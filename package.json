{
  "name": "confeti",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "description": "Galerie open source pour créer un site d'anniversaire à offrir, sans coder : personnalise un modèle dans le navigateur et télécharge un seul fichier HTML.",
  "keywords": [
    "anniversaire",
    "site-anniversaire",
    "carte-virtuelle",
    "cadeau",
    "html",
    "astro",
    "open-source",
    "scroll-narratif"
  ],
  "homepage": "https://www.confeti.fun",
  "repository": {
    "type": "git",
    "url": "https://github.com/DemeulemeesterxMaxime/Confeti.git"
  },
  "license": "MIT",
  "author": "Maxime Demeulemeester",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint . && astro check",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.8"
  },
  "overrides": {
    "path-to-regexp@6.1.0": "6.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.9",
    "audit-ci": "^7.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
