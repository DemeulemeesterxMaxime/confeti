---
import { getLangFromUrl, localizePath, languages, t } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const tt = t[lang];

const {
  title = "Confeti — Crée et offre un site d'anniversaire unique",
  description = "Crée et offre un site d'anniversaire qui se raconte au scroll : photos, messages et musique assemblés en un seul fichier HTML à partager. Sans coder, 100 % gratuit.",
  active = '',
  canonical = Astro.url.href,
  ogImage = 'https://confeti.fun/og-image.svg',
  // Graphes JSON-LD additionnels propres a la page (objet ou tableau d'objets).
  jsonLd = [],
} = Astro.props;

const siteUrl = 'https://confeti.fun';

// Liens alternes par langue (hreflang) pour la page courante.
const frHref = siteUrl + localizePath(Astro.url.pathname, 'fr');
const enHref = siteUrl + localizePath(Astro.url.pathname, 'en');
// Chemin de la page courante dans l'autre langue (bouton de bascule).
const altLang = lang === 'fr' ? 'en' : 'fr';
const altHref = localizePath(Astro.url.pathname, altLang);
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';

// Entites de base, communes a toutes les pages : l'organisation editrice et
// l'application web, reliees par @id pour le graphe de connaissances.
const baseGraph = [
  {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'Confeti',
    url: siteUrl,
    logo: 'https://confeti.fun/icon.svg',
  },
  {
    '@type': 'WebApplication',
    '@id': `${siteUrl}/#app`,
    name: 'Confeti',
    url: siteUrl,
    description,
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'All',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    inLanguage: lang,
    publisher: { '@id': `${siteUrl}/#organization` },
  },
];

// Fusionne les graphes de base avec ceux fournis par la page.
const pageGraph = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [...baseGraph, ...pageGraph],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Confeti" />
    <meta name="theme-color" content="#ef5d57" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={frHref} />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Confeti" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='46' fill='%23ef5d57'/%3E%3Ctext x='50' y='72' font-size='62' font-family='Nunito,sans-serif' font-weight='800' fill='white' text-anchor='middle'%3EC%3C/text%3E%3C/svg%3E"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Nunito:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --cream: #fdf7ee;
        --surface: #fff;
        --ink: #2b2435;
        --muted: #6b6175;
        --faint: #a0959f;
        --line: #efe6d8;
        --cream2: #f4ece0;
        --coral: #ef5d57;
        --coral-d: #d9483f;
        --coral-soft: #ffe3dd;
        --gold: #f5b13d;
        --blue: #3d9be0;
        --green: #2bb38a;
        --purple: #7c5cd6;
        --shadow: 0 8px 22px rgba(120, 90, 60, 0.07);
        --shadow-l: 0 20px 56px rgba(120, 90, 60, 0.14);
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      /* Scrollbar discrète, dans la charte (Firefox) */
      html {
        scrollbar-width: thin;
        scrollbar-color: var(--line) transparent;
      }
      /* Scrollbar discrète (Chrome, Edge, Safari) */
      ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: var(--line);
        border-radius: 999px;
        border: 2px solid var(--cream);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--coral);
      }
      body {
        background: var(--cream);
        color: var(--ink);
        font-family: 'Nunito', sans-serif;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      /* Sticky footer : le main pousse le footer en bas même si le contenu est court */
      main {
        flex: 1 0 auto;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .wrap {
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .serif {
        font-family: 'Cormorant Garamond', serif;
      }

      /* Header */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }
      .nav-in {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 62px;
        gap: 16px;
      }
      .logo {
        display: inline-flex;
        align-items: center;
        font-weight: 800;
        font-size: 23px;
        color: var(--ink);
        letter-spacing: -0.01em;
      }
      .logo .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--coral);
        display: inline-block;
        margin-left: 4px;
      }
      .nav nav {
        display: flex;
        align-items: center;
        gap: 24px;
        font-weight: 700;
        font-size: 14px;
        color: var(--muted);
      }
      .nav nav a:hover {
        color: var(--ink);
      }
      .nav nav a.on {
        color: var(--ink);
      }
      .nav nav a.lang {
        border: 1.5px solid var(--line);
        border-radius: 999px;
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 800;
        color: var(--muted);
        letter-spacing: 0.02em;
      }
      .nav nav a.lang:hover {
        border-color: var(--coral);
        color: var(--ink);
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 22px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 14px;
        cursor: pointer;
        border: 2px solid transparent;
        transition:
          transform 0.12s,
          filter 0.15s,
          background 0.15s,
          color 0.15s;
        white-space: nowrap;
      }
      .btn:hover {
        transform: translateY(-1px);
      }
      .btn.primary {
        background: var(--coral);
        color: #fff;
        box-shadow: 0 10px 24px rgba(239, 93, 87, 0.3);
      }
      .btn.primary:hover {
        filter: brightness(1.04);
      }
      .btn.dark {
        background: var(--ink);
        color: #fff;
      }
      .btn.ghost {
        background: transparent;
        border-color: var(--ink);
        color: var(--ink);
      }
      .btn.soft {
        background: var(--surface);
        border-color: var(--line);
        color: var(--ink);
      }
      .btn.sm {
        padding: 9px 16px;
        font-size: 13px;
      }
      .btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
      }

      /* Bits */
      .pill {
        display: inline-block;
        padding: 7px 15px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
      }
      .pill.coral {
        background: var(--coral-soft);
        color: var(--coral-d);
      }
      .pill.green {
        background: #e0f3ea;
        color: #1e7a56;
      }
      .pill.blue {
        background: #deeefb;
        color: #2570a6;
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 20px;
        box-shadow: var(--shadow);
      }
      h1,
      h2,
      h3 {
        color: var(--ink);
      }

      /* Footer */
      footer.site {
        border-top: 1px solid var(--line);
        margin-top: 28px;
      }
      footer.site .in {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding: 26px 0;
        color: var(--faint);
        font-size: 13px;
      }
      footer.site a {
        color: var(--muted);
        font-weight: 700;
      }
      footer.site a:hover {
        color: var(--ink);
      }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="nav-in wrap">
        <a class="logo" href={localizePath('/', lang)}>Confeti<span class="dot"></span></a>
        <nav>
          <a href={localizePath('/galerie', lang)} class={active === 'galerie' ? 'on' : ''}
            >{tt.nav.gallery}</a
          >
          <a href={localizePath('/create', lang)} class={active === 'create' ? 'on' : ''}
            >{tt.nav.create}</a
          >
          <a href={localizePath('/deploy', lang)} class={active === 'deploy' ? 'on' : ''}
            >{tt.nav.deploy}</a
          >
          <a class="lang" href={altHref} hreflang={altLang} aria-label={tt.langLabel}
            >{languages[altLang]}</a
          >
          <a class="btn dark sm" href={localizePath('/galerie', lang)}>{tt.nav.start}</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="in wrap">
        <span>{tt.footer.tagline}</span>
        <span>
          <a href="https://github.com/DemeulemeesterxMaxime/Confeti" target="_blank" rel="noopener"
            >GitHub</a
          >
          &nbsp;·&nbsp;
          <a href={localizePath('/deploy', lang)}>{tt.footer.host}</a>
        </span>
      </div>
    </footer>

    <script>
      // Met les apercus iframe (concus en 1280x832) a l'echelle de leur conteneur.
      function scalePreviews() {
        document.querySelectorAll<HTMLElement>('.prev').forEach((box) => {
          const w = box.clientWidth;
          if (!w) return;
          const s = w / 1280;
          const f = box.querySelector('iframe');
          if (f) f.style.transform = 'scale(' + s + ')';
          box.style.height = Math.round(832 * s) + 'px';
        });
      }
      scalePreviews();
      window.addEventListener('resize', scalePreviews);
      window.addEventListener('load', scalePreviews);
      setTimeout(scalePreviews, 300);
    </script>
  </body>
</html>
