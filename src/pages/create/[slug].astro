---
import Base from '../../layouts/Base.astro';
import { getTemplates } from '../../lib/templates.js';
import { MASCOTS, DEFAULT_MASCOT } from '../../lib/mascots.js';

export function getStaticPaths() {
  return getTemplates().map((t) => ({ params: { slug: t.slug }, props: { tpl: t } }));
}

const { tpl } = Astro.props;
---
<Base
  title={`Personnaliser ${tpl.title} - Confetti`}
  description={`Personnalise le modèle "${tpl.title}" : textes, photos, musique et couleurs. Télécharge un site HTML prêt à offrir en quelques minutes.`}
  active="create"
>
  <div class="topbar">
    <div class="wrap topbar-in">
      <div class="bread"><a href="/galerie">Galerie</a><span>/</span><b>{tpl.title}</b></div>
      <div class="acts">
        <button class="btn soft sm" id="openBig">Aperçu plein écran</button>
        <button class="btn primary sm" id="dl">⬇ Télécharger le site</button>
      </div>
    </div>
  </div>

  <div class="wrap ed-grid">
    <section class="preview-col">
      <div class="preview-head">
        <div class="eyebrow">Aperçu en direct</div>
        <div class="seg" role="tablist" aria-label="Mode d'aperçu">
          <button class="seg-b is-on" id="modePhone" type="button" role="tab" aria-selected="true">📱 Téléphone</button>
          <button class="seg-b" id="modeDesktop" type="button" role="tab" aria-selected="false">🖥 Ordinateur</button>
        </div>
      </div>
      <div class="stage phone" id="stage">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="screen"><iframe id="preview" title="Aperçu en direct"></iframe></div>
      </div>
      <p class="muted small center">Mise à jour en temps réel</p>
    </section>

    <aside class="panel card">
      <div class="panel-h">
        <h2>Réglages</h2>
        <a class="pill coral" href="/create" title="Bientôt">✨ Réécrire par IA</a>
      </div>

      <p class="loading" id="loadingMsg">Chargement du modèle…</p>

      <div id="form" hidden>
        <div id="fields"></div>

        <div class="sec">
          <div class="sec-h"><div class="sec-t">Photos</div><span class="count" id="photoCount"></span></div>
          <div id="slots" class="slots"></div>
        </div>

        <div class="sec" id="mascotSec" hidden>
          <div class="sec-t">Mascotte</div>
          <div id="mascots" class="mascot-grid"></div>
        </div>

        <div class="sec" id="bgSec" hidden>
          <div class="sec-t">Couleur de fond</div>
          <div id="bgControls" class="bg-controls"></div>
        </div>

        <div class="sec">
          <div class="sec-t">Musique (optionnel)</div>
          <label class="drop" id="musicLabel" for="music">♪ Déposer un .mp3</label>
          <input type="file" id="music" accept="audio/*" hidden />
          <p class="muted small" id="musicInfo">Démarre à la première interaction (iOS). Alourdit le fichier.</p>
        </div>

        <button class="btn primary big" id="dl2">⬇ Télécharger le site</button>
        <p class="muted small center" id="sizeNote"></p>
        <p class="muted small center">Un seul fichier .html · photos & musique intégrées</p>
      </div>
    </aside>
  </div>
</Base>

<script define:vars={{ tplUrl: tpl.url, MASCOTS, DEFAULT_MASCOT }}>
  const $ = (s) => document.querySelector(s);
  const fieldsEl = $('#fields');
  const slotsEl = $('#slots');
  const previewEl = $('#preview');

  // Masque la scroll bar dans l'aperçu uniquement (jamais dans le fichier téléchargé).
  const NOSCROLL = '<style>html,body{scrollbar-width:none;-ms-overflow-style:none}'
    + 'html::-webkit-scrollbar,body::-webkit-scrollbar{width:0;height:0;display:none}</style>';
  const formEl = $('#form');
  const loadingEl = $('#loadingMsg');
  const sizeNote = $('#sizeNote');
  const photoCount = $('#photoCount');

  let baseDoc = null;
  const edits = {};
  const images = {};
  let musicDataUrl = null;
  let slotTotal = 0, slotDone = 0;
  let bgColor = null;          // couleur de fond choisie (null = dégradé d'origine)
  let mascotId = DEFAULT_MASCOT; // mascotte choisie ('panda' = dessin d'origine)

  // Assombrit une couleur hex par un facteur (1 = inchangé, 0 = noir).
  function shade(hex, f) {
    const m = /^#?([0-9a-f]{6})$/i.exec(hex);
    if (!m) return hex;
    const n = parseInt(m[1], 16);
    const r = Math.round(((n >> 16) & 255) * f);
    const g = Math.round(((n >> 8) & 255) * f);
    const b = Math.round((n & 255) * f);
    return '#' + ((1 << 24) | (r << 16) | (g << 8) | b).toString(16).slice(1);
  }

  // Reconstruit le dégradé "ciel nocturne" à partir d'une couleur de base.
  function bgGradient(base) {
    return 'radial-gradient(125% 95% at 50% 8%, ' + shade(base, 1) + ' 0%, '
      + shade(base, 0.72) + ' 36%, ' + shade(base, 0.45) + ' 74%, '
      + shade(base, 0.28) + ' 100%)';
  }

  function labelFor(key) {
    if (key === 'opening.eyebrow') return 'Ouverture : sur-titre';
    if (key === 'opening.title') return 'Ouverture : titre';
    if (key === 'finale.eyebrow') return 'Finale : sur-titre';
    if (key === 'finale.title') return 'Finale : titre';
    if (key === 'finale.sub') return 'Finale : sous-titre';
    return key;
  }

  function subheader(text) {
    const d = document.createElement('div');
    d.className = 'sub-t';
    d.textContent = text;
    fieldsEl.appendChild(d);
  }

  // Une "carte champ" : etiquette coral + zone editable integree (style maquette)
  function fieldCard(key, label, opts) {
    opts = opts || {};
    edits[key] = edits[key] != null ? edits[key] : '';
    const card = document.createElement('div');
    card.className = 'fld' + (opts.cls ? ' ' + opts.cls : '');
    const k = document.createElement('div');
    k.className = 'fld-k';
    k.textContent = label;
    const input = opts.multiline ? document.createElement('textarea') : document.createElement('input');
    if (opts.multiline) input.rows = 2;
    input.value = edits[key];
    input.addEventListener('input', () => { edits[key] = input.value; scheduleRender(); });
    card.appendChild(k);
    card.appendChild(input);
    fieldsEl.appendChild(card);
    return card;
  }

  function buildForm() {
    const editEls = Array.prototype.slice.call(baseDoc.querySelectorAll('[data-edit]'));
    const keys = editEls.map((el) => {
      edits[el.getAttribute('data-edit')] = (el.textContent || '').trim();
      return el.getAttribute('data-edit');
    });

    // Prenom
    if (keys.indexOf('name') > -1) {
      fieldCard('name', 'Prénom', { cls: 'name' });
    }

    // Scenes (sN.kicker + sN.line) groupees en cartes
    const sceneNums = [];
    keys.forEach((k) => {
      const m = k.match(/^s(\d+)\./);
      if (m && sceneNums.indexOf(+m[1]) === -1) sceneNums.push(+m[1]);
    });
    sceneNums.sort((a, b) => a - b);
    if (sceneNums.length) {
      subheader('Messages');
      sceneNums.forEach((n) => {
        const kk = 's' + n + '.kicker', lk = 's' + n + '.line';
        const card = document.createElement('div');
        card.className = 'fld scene';
        if (keys.indexOf(kk) > -1) {
          const ki = document.createElement('input');
          ki.className = 'k-in';
          ki.value = edits[kk] || '';
          ki.addEventListener('input', () => { edits[kk] = ki.value; scheduleRender(); });
          card.appendChild(ki);
        }
        if (keys.indexOf(lk) > -1) {
          const li = document.createElement('textarea');
          li.className = 'l-in';
          li.rows = 2;
          li.value = edits[lk] || '';
          li.addEventListener('input', () => { edits[lk] = li.value; scheduleRender(); });
          card.appendChild(li);
        }
        fieldsEl.appendChild(card);
      });
    }

    // Ouverture & finale
    const extra = keys.filter((k) => /^(opening|finale)\./.test(k));
    if (extra.length) {
      subheader('Ouverture & finale');
      extra.forEach((k) => fieldCard(k, labelFor(k), {}));
    }

    // Photos
    const slotEls = Array.prototype.slice.call(baseDoc.querySelectorAll('[data-slot]'));
    slotTotal = slotEls.length;
    updateCount();
    slotEls.forEach((el) => {
      const n = el.getAttribute('data-slot');
      const cell = document.createElement('label');
      cell.className = 'slot';
      const thumb = document.createElement('div');
      thumb.className = 'thumb';
      thumb.textContent = '+';
      const file = document.createElement('input');
      file.type = 'file';
      file.accept = 'image/*';
      file.hidden = true;
      file.addEventListener('change', () => {
        const f = file.files && file.files[0];
        if (!f) return;
        const r = new FileReader();
        r.onload = () => {
          if (!images[n]) slotDone++;
          images[n] = r.result;
          thumb.style.backgroundImage = 'url(' + r.result + ')';
          thumb.classList.add('filled');
          thumb.textContent = '';
          updateCount();
          scheduleRender();
        };
        r.readAsDataURL(f);
      });
      cell.appendChild(thumb);
      cell.appendChild(file);
      slotsEl.appendChild(cell);
    });

    buildMascots();
    buildBgControls();

    $('#music').addEventListener('change', (e) => {
      const f = e.target.files && e.target.files[0];
      if (!f) return;
      $('#musicLabel').textContent = '♪ ' + f.name;
      $('#musicLabel').classList.add('set');
      const r = new FileReader();
      r.onload = () => { musicDataUrl = r.result; scheduleRender(); };
      r.readAsDataURL(f);
    });

    $('#dl').addEventListener('click', download);
    $('#dl2').addEventListener('click', download);
    $('#openBig').addEventListener('click', openBig);

    // Bascule Téléphone / Ordinateur (un seul aperçu à la fois)
    const stage = $('#stage'), bPhone = $('#modePhone'), bDesk = $('#modeDesktop');
    const screen = stage.querySelector('.screen');
    // Viewports simulés : la template est rendue à ces dimensions puis réduite.
    const DESK_W = 1280, DESK_H = 800, PHONE_W = 390, PHONE_H = 844;

    // L'iframe est rendu à un vrai viewport (mobile ou desktop) puis mis à
    // l'échelle pour tenir dans le cadre : mise en page fidèle, en miniature.
    function fitPreview() {
      const desktop = stage.classList.contains('desktop');
      const w = desktop ? DESK_W : PHONE_W, h = desktop ? DESK_H : PHONE_H;
      const cw = screen.clientWidth;
      if (!cw) return;
      const s = cw / w;
      previewEl.style.transform = 'scale(' + s + ')';
      screen.style.height = (h * s) + 'px';
    }

    function setMode(desktop) {
      stage.classList.toggle('desktop', desktop);
      stage.classList.toggle('phone', !desktop);
      bDesk.classList.toggle('is-on', desktop);
      bPhone.classList.toggle('is-on', !desktop);
      bDesk.setAttribute('aria-selected', String(desktop));
      bPhone.setAttribute('aria-selected', String(!desktop));
      fitPreview();                  // estimation immédiate (pendant la transition)
      setTimeout(fitPreview, 300);   // recalcul une fois la largeur figée (transition .25s)
    }
    bPhone.addEventListener('click', () => setMode(false));
    bDesk.addEventListener('click', () => setMode(true));
    // La largeur du cadre change avec une transition : on recale à sa fin.
    stage.addEventListener('transitionend', (e) => { if (e.propertyName === 'max-width') fitPreview(); });
    window.addEventListener('resize', fitPreview);
    fitPreview(); // mise à l'échelle initiale (mode téléphone par défaut)
  }

  function updateCount() { if (photoCount) photoCount.textContent = slotDone + ' / ' + slotTotal + ' ajoutées'; }

  // Galerie de mascottes (affichée seulement si la template déclare [data-mascot]).
  function buildMascots() {
    if (!baseDoc.querySelector('[data-mascot]')) return;
    const wrap = $('#mascots');
    MASCOTS.forEach((m) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'mascot' + (m.id === mascotId ? ' is-on' : '');
      b.setAttribute('aria-pressed', String(m.id === mascotId));
      b.innerHTML = '<span class="m-glyph">' + (m.glyph || '🐼') + '</span>'
        + '<span class="m-lab">' + m.label + '</span>';
      b.addEventListener('click', () => {
        mascotId = m.id;
        wrap.querySelectorAll('.mascot').forEach((x) => {
          const on = x === b;
          x.classList.toggle('is-on', on);
          x.setAttribute('aria-pressed', String(on));
        });
        scheduleRender();
      });
      wrap.appendChild(b);
    });
    $('#mascotSec').hidden = false;
  }

  // Contrôles de couleur de fond (affichés seulement si la template déclare [data-bg]).
  function buildBgControls() {
    const bgEl = baseDoc.querySelector('[data-bg]');
    if (!bgEl) return;
    const base = bgEl.getAttribute('data-bg') || '#1d3666';
    bgColor = bgColor || base;
    const wrap = $('#bgControls');
    const PRESETS = ['#1d3666', '#3a2350', '#7a2e3a', '#1f4d3a', '#2b2f38', '#5a3a1e'];
    const swatches = document.createElement('div');
    swatches.className = 'bg-swatches';
    const picker = document.createElement('input');
    picker.type = 'color';
    picker.className = 'bg-picker';
    picker.value = bgColor;
    function apply(c) {
      bgColor = c;
      picker.value = c;
      swatches.querySelectorAll('.bg-sw').forEach((s) => s.classList.toggle('is-on', s.dataset.c === c));
      scheduleRender();
    }
    PRESETS.forEach((c) => {
      const s = document.createElement('button');
      s.type = 'button';
      s.className = 'bg-sw' + (c === bgColor ? ' is-on' : '');
      s.dataset.c = c;
      s.style.background = bgGradient(c);
      s.title = c;
      s.addEventListener('click', () => apply(c));
      swatches.appendChild(s);
    });
    picker.addEventListener('input', () => apply(picker.value));
    const row = document.createElement('label');
    row.className = 'bg-pickrow';
    row.appendChild(Object.assign(document.createElement('span'), { textContent: 'Couleur personnalisée' }));
    row.appendChild(picker);
    wrap.appendChild(swatches);
    wrap.appendChild(row);
    $('#bgSec').hidden = false;
  }

  function buildDoc() {
    const doc = baseDoc.cloneNode(true);
    doc.querySelectorAll('[data-edit]').forEach((el) => {
      const k = el.getAttribute('data-edit');
      if (edits[k] != null) el.textContent = edits[k];
    });
    if (edits['name']) {
      const t = doc.querySelector('title');
      if (t) t.textContent = 'Joyeux anniversaire ' + edits['name'];
    }
    doc.querySelectorAll('[data-slot]').forEach((el) => {
      const n = el.getAttribute('data-slot');
      if (images[n]) {
        el.textContent = '';
        el.style.background = 'center / cover no-repeat #11131a';
        el.style.backgroundImage = 'url(' + images[n] + ')';
      }
    });
    if (musicDataUrl) {
      const audio = doc.querySelector('[data-audio]');
      if (audio) audio.setAttribute('src', musicDataUrl);
    }
    if (bgColor) {
      doc.querySelectorAll('[data-bg]').forEach((el) => { el.style.background = bgGradient(bgColor); });
    }
    if (mascotId && mascotId !== DEFAULT_MASCOT) {
      const m = MASCOTS.find((x) => x.id === mascotId);
      if (m && m.glyph) {
        doc.querySelectorAll('[data-mascot]').forEach((el) => {
          const size = parseInt(el.getAttribute('data-mascot-size') || '120', 10);
          el.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;'
            + 'width:100%;height:100%;font-size:' + Math.round(size * 0.82) + 'px;line-height:1;">'
            + m.glyph + '</div>';
        });
      }
    }
    return doc;
  }

  const serialize = (doc) => '<!doctype html>\n' + doc.documentElement.outerHTML;

  let timer = null;
  function scheduleRender() { clearTimeout(timer); timer = setTimeout(render, 220); }

  function render() {
    const html = serialize(buildDoc());
    const previewHtml = html.includes('</head>')
      ? html.replace('</head>', NOSCROLL + '</head>')
      : NOSCROLL + html;
    previewEl.srcdoc = previewHtml;
    const mo = new Blob([html]).size / 1e6;
    sizeNote.textContent = 'Fichier estimé : ' + mo.toFixed(mo < 1 ? 2 : 1) + ' Mo'
      + (musicDataUrl ? ' (musique incluse)' : '');
  }

  function fileName() {
    const base = (edits['name'] || 'fete').toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    return 'confetti-' + (base || 'fete') + '.html';
  }

  function download() {
    const blob = new Blob([serialize(buildDoc())], { type: 'text/html' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = fileName();
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(a.href), 2000);
  }

  function openBig() {
    const blob = new Blob([serialize(buildDoc())], { type: 'text/html' });
    window.open(URL.createObjectURL(blob), '_blank');
  }

  async function init() {
    try {
      const res = await fetch(tplUrl);
      const txt = await res.text();
      baseDoc = new DOMParser().parseFromString(txt, 'text/html');
      buildForm();
      loadingEl.hidden = true;
      formEl.hidden = false;
      render();
    } catch (e) {
      loadingEl.textContent = 'Impossible de charger le modèle : ' + e;
    }
  }

  init();
</script>

<style>
  .topbar { background:var(--surface); border-bottom:1px solid var(--line); position:sticky; top:62px; z-index:30; }
  .topbar-in { display:flex; align-items:center; justify-content:space-between; gap:14px; height:58px; }
  .bread { display:flex; align-items:center; gap:10px; font-weight:700; font-size:13px; color:var(--faint); }
  .bread a:hover { color:var(--ink); }
  .bread b { color:var(--ink); }
  .acts { display:flex; gap:10px; }

  .ed-grid { display:grid; grid-template-columns:minmax(0,1fr) 410px; gap:28px; padding:24px; align-items:start; }
  .preview-col { position:sticky; top:140px; }
  .eyebrow { font-weight:700; font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--faint); margin-bottom:12px; }
  /* En-tête aperçu : titre + bascule */
  .preview-head { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px; }
  .preview-head .eyebrow { margin-bottom:0; }
  .seg { display:inline-flex; padding:3px; gap:2px; background:var(--cream); border:1px solid var(--line); border-radius:10px; }
  .seg-b { border:0; background:transparent; cursor:pointer; padding:6px 12px; border-radius:8px; font:inherit; font-weight:700; font-size:12px; color:var(--faint); transition:background .15s, color .15s; }
  .seg-b.is-on { background:var(--surface); color:var(--ink); box-shadow:0 1px 3px rgba(120,90,60,.12); }

  /* Cadre d'aperçu : un seul iframe, deux formes selon le mode */
  .stage { margin:0 auto; overflow:hidden; background:#0a1430; box-shadow:0 26px 54px rgba(120,90,60,.16); transition:max-width .25s ease, border-radius .25s ease, padding .25s ease; }
  .stage .screen { overflow:hidden; background:#0a1430; }
  .stage iframe { display:block; border:0; background:#0a1430; transform-origin:top left; }
  .stage .browser-bar { height:26px; background:#f4ece0; display:flex; align-items:center; gap:6px; padding:0 11px; }
  .stage .browser-bar span { width:8px; height:8px; border-radius:50%; }
  .stage .browser-bar span:nth-child(1) { background:#ff5f57; }
  .stage .browser-bar span:nth-child(2) { background:#febc2e; }
  .stage .browser-bar span:nth-child(3) { background:#28c840; }

  /* Les deux modes rendent la template à un vrai viewport puis la réduisent
     par transform:scale (cf. fitPreview), pour une mise en page fidèle. */

  /* Mode téléphone : cadre sombre arrondi, viewport mobile 390px */
  .stage.phone { max-width:248px; border-radius:38px; padding:9px; border:1px solid rgba(255,255,255,.13); }
  .stage.phone .browser-bar { display:none; }
  .stage.phone .screen { border-radius:30px; }
  .stage.phone iframe { width:390px; height:844px; }

  /* Mode ordinateur : fenêtre navigateur, viewport desktop 1280px */
  .stage.desktop { max-width:760px; border-radius:12px; padding:0; border:1px solid var(--line); box-shadow:0 16px 36px rgba(120,90,60,.1); }
  .stage.desktop .screen { width:100%; }
  .stage.desktop iframe { width:1280px; height:800px; }
  .center { text-align:center; }
  .small { font-size:12px; }
  .muted { color:var(--faint); }

  .panel { padding:22px; }
  .panel-h { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .panel-h h2 { font-size:16px; font-weight:800; margin:0; }
  .panel-h .pill { text-decoration:none; }
  .loading { color:var(--faint); }

  /* Champs générés en JS : voir le bloc <style is:global> plus bas
     (le style scoped d'Astro ne s'applique pas aux éléments createElement). */

  .sec { padding:16px 0 0; margin-top:16px; border-top:1px solid var(--line); }
  .sec-h { display:flex; align-items:center; justify-content:space-between; }
  .sec-t { font-weight:800; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--faint); margin-bottom:10px; }
  .sec-h .sec-t { margin-bottom:0; }
  .count { font-weight:700; font-size:11px; color:var(--faint); }

  .slots { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-top:10px; }

  .drop { display:block; text-align:center; border-radius:11px; border:1.5px dashed var(--line); background:var(--cream); padding:13px; font-weight:700; font-size:13px; color:var(--faint); cursor:pointer; transition:border-color .15s, color .15s; }
  .drop:hover { border-color:var(--coral); color:var(--coral); }
  .drop.set { border-style:solid; color:var(--ink); }

  .btn.big { width:100%; padding:14px; margin-top:14px; }

  @media (max-width:900px) {
    .ed-grid { grid-template-columns:1fr; }
    .preview-col { position:static; order:-1; }
    .topbar { position:static; }
  }
</style>

<!-- Champs construits en JS : non scopés par Astro, donc stylés en global
     et ancrés sur .ed-grid pour rester confinés à cet écran. -->
<style is:global>
  .ed-grid .sub-t { font-weight:800; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--faint); margin:18px 0 9px; }
  .ed-grid .sub-t:first-child { margin-top:4px; }

  /* Carte champ (style maquette) */
