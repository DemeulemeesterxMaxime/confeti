---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { getTemplates } from '../lib/templates.js';

const templates = getTemplates();
const cats = Array.from(new Set(templates.map((t) => t.category))).filter(Boolean);
---

<Base
  title="Galerie de modèles d'anniversaire - Confeti"
  description="Parcours nos modèles de sites d'anniversaire : romantique, festif, enfant... Choisis ton ambiance, personnalise en quelques clics et télécharge un site prêt à offrir."
  active="galerie"
>
  <section class="wrap head">
    <h1>La galerie 🎈</h1>
    <p>Des modèles partagés par la communauté. Choisis-en un, personnalise, télécharge.</p>
    <div class="filters">
      <button class="chip on" data-cat="*">Tous</button>
      {
        cats.map((c) => (
          <button class="chip" data-cat={c}>
            {c}
          </button>
        ))
      }
      <input id="q" class="search" type="search" placeholder="🔍  Rechercher…" />
    </div>
  </section>

  <section class="wrap grid">
    {templates.map((t) => <Card t={t} />)}

    <a class="make" href="/create">
      <div class="make-t">Crée le tien ✨</div>
      <div class="make-d">Pars d'un modèle ou laisse l'IA écrire l'histoire.</div>
      <div class="make-b">
        <span class="btn primary sm">✨ Créer par IA</span>
        <span class="btn ghost sm">Partir d'un modèle</span>
      </div>
    </a>
  </section>
</Base>

<script>
  const chips = Array.from(document.querySelectorAll('.chip'));
  const q = document.getElementById('q') as HTMLInputElement | null;
  let cat = '*';
  function apply() {
    const term = ((q && q.value) || '').trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('.tcard').forEach((c) => {
      const okCat = cat === '*' || c.getAttribute('data-cat') === cat;
      const okTerm = !term || (c.getAttribute('data-name') || '').includes(term);
      c.style.display = okCat && okTerm ? '' : 'none';
    });
  }
  chips.forEach((ch) =>
    ch.addEventListener('click', () => {
      chips.forEach((x) => x.classList.remove('on'));
      ch.classList.add('on');
      cat = ch.getAttribute('data-cat');
      apply();
    }),
  );
  if (q) q.addEventListener('input', apply);
</script>

<style>
  .head {
    padding: 32px 24px 20px;
  }
  .head h1 {
    font-size: 36px;
    font-weight: 800;
    margin: 0;
  }
  .head p {
    color: var(--muted);
    margin: 6px 0 0;
    font-size: 15px;
  }
  .filters {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .chip {
    padding: 9px 18px;
    border-radius: 999px;
    border: 1.5px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .chip:hover {
    border-color: var(--coral);
  }
  .chip.on {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }
  .search {
    margin-left: auto;
    width: 240px;
    max-width: 100%;
    height: 40px;
    border-radius: 999px;
    border: 1.5px solid var(--line);
    background: var(--surface);
    padding: 0 16px;
    font: inherit;
    font-size: 13px;
    color: var(--ink);
  }
  .search:focus {
    outline: none;
    border-color: var(--coral);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
    padding-bottom: 10px;
  }

  .make {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 2px dashed var(--gold);
    background: #fffdf5;
    border-radius: 20px;
    padding: 22px;
    min-height: 280px;
  }
  .make-t {
    font-size: 22px;
    font-weight: 800;
  }
  .make-d {
    color: var(--muted);
    font-size: 13px;
    margin: 6px 0 18px;
  }
  .make-b {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .make-b .btn {
    width: 100%;
  }
</style>
