---
import Base from '../layouts/Base.astro';
import { getTemplates } from '../lib/templates.js';

const templates = getTemplates();
---
<Base>
  <section class="hero">
    <p class="eyebrow">Open source - sans base de donnees - 100% offert</p>
    <h1>Offre un site d'anniversaire<br />qui se raconte au scroll.</h1>
    <p class="sub">
      Choisis un modele, ajoute tes photos, tes mots et ta musique, puis telecharge
      un fichier unique pret a heberger. Fonctionne sur iPhone et ordinateur.
    </p>
    <div class="cta">
      {templates[0] && <a class="btn primary" href={templates[0].editUrl}>Personnaliser un modele</a>}
      <a class="btn" href="/deploy">Comment heberger ?</a>
    </div>
  </section>

  <section class="gallery">
    <div class="gallery-head">
      <h2>Modeles ({templates.length})</h2>
      <span class="hint">Ajoute le tien : depose un dossier dans <code>public/templates/</code></span>
    </div>

    {templates.length === 0 && (
      <p class="empty">Aucun modele pour l'instant. Ajoute un dossier dans <code>public/templates/</code>.</p>
    )}

    <div class="grid">
      {templates.map((t) => (
        <article class="card" style={`--accent:${t.accent}`}>
          <a class="preview" href={t.editUrl} aria-label={`Personnaliser ${t.title}`}>
            <iframe
              src={t.url}
              width="1280"
              height="832"
              loading="lazy"
              scrolling="no"
              tabindex="-1"
              title={`Apercu ${t.title}`}
            ></iframe>
            <span class="open">Personnaliser</span>
          </a>
          <div class="meta">
            <div class="row">
              <h3>{t.title}</h3>
              {t.hasMusic && <span class="badge" title="Musique incluse">♪</span>}
            </div>
            {t.description && <p class="desc">{t.description}</p>}
            <div class="actions">
              <a class="btn primary" href={t.editUrl}>Personnaliser</a>
              <a class="btn" href={t.url} target="_blank" rel="noopener">Voir en plein ecran</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero { text-align:center; padding:46px 0 34px; }
  .eyebrow { letter-spacing:.32em; text-transform:uppercase; font-size:12px; color:var(--gold); margin:0 0 14px; }
  .hero h1 { font-size:clamp(34px,6vw,64px); line-height:1.04; margin:0 0 18px; }
  .hero .sub { max-width:620px; margin:0 auto 26px; color:var(--muted); font-size:17px; line-height:1.6; }
  .cta { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }

  .gallery { padding-top:18px; }
  .gallery-head { display:flex; align-items:baseline; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:18px; }
  .gallery-head h2 { font-size:26px; margin:0; }
  .hint { color:var(--muted); font-size:13px; }
  code { background:rgba(156,192,255,.12); padding:2px 7px; border-radius:6px; font-size:.92em; }
  .empty { color:var(--muted); }

  .grid { display:grid; grid-template-columns:repeat(auto-fill, 340px); gap:26px; justify-content:center; }

  .card { width:340px; background:var(--card); border:1px solid var(--line); border-radius:16px; overflow:hidden; transition:transform .18s, border-color .18s; }
  .card:hover { transform:translateY(-4px); border-color:var(--accent); }

  .preview { display:block; position:relative; width:340px; height:221px; overflow:hidden; background:#0a1430; border-bottom:1px solid var(--line); }
  /* iframe 1280x832 reduit pour tenir dans 340x221 (facteur 0.2656) */
  .preview iframe { position:absolute; top:0; left:0; border:0; transform:scale(.2656); transform-origin:top left; pointer-events:none; }
  .preview .open { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(8,18,44,.0); color:#fff; font-weight:700; opacity:0; transition:opacity .18s; }
  .card:hover .preview .open { opacity:1; background:rgba(8,18,44,.55); }

  .meta { padding:16px 16px 18px; }
  .row { display:flex; align-items:center; justify-content:space-between; gap:10px; }
  .meta h3 { font-size:22px; margin:0; }
  .badge { color:var(--accent); border:1px solid var(--line); border-radius:999px; width:26px; height:26px; display:inline-flex; align-items:center; justify-content:center; font-size:13px; }
  .desc { color:var(--muted); font-size:14px; line-height:1.5; margin:8px 0 14px; }
  .actions { display:flex; gap:10px; flex-wrap:wrap; }
  .actions .btn { padding:8px 14px; font-size:13px; }
</style>
