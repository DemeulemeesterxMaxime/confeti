---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { getTemplates } from '../lib/templates.js';

const templates = getTemplates();
const featured = templates.slice(0, 3);
const hero = templates[0];
---
<Base
  title="Confetti — Crée un site d'anniversaire à offrir, sans coder"
  description="Choisis un modèle, personnalise les textes et les photos, ajoute une musique : tu repars avec un seul fichier HTML à partager. Gratuit, sans inscription."
>
  <section class="hero">
    <span class="confetti c1"></span><span class="confetti c2"></span><span class="confetti c3"></span>
    <span class="confetti c4"></span><span class="confetti c5"></span><span class="confetti c6"></span>
    <div class="wrap hero-in">
      <div class="hero-text">
        <span class="pill coral">🎉 Sans coder · 100% gratuit</span>
        <h1>Un site pour chaque occasion,<br />prêt à <span class="hl">offrir</span>.</h1>
        <p class="lead">
          Anniversaire, fête des mères ou des pères, une bonne nouvelle... Tes photos,
          tes mots, une musique : on assemble un site qui défile comme une histoire, et
          tu repars avec un seul fichier à partager.
        </p>
        <div class="cta">
          <a class="btn primary" href="/galerie">Parcourir la galerie</a>
          <a class="btn ghost" href="/create">✨ Créer par IA</a>
        </div>
        <div class="proof">
          <div class="avatars">
            <span style="background:#3d9be0"></span>
            <span style="background:#2bb38a"></span>
            <span style="background:#f5b13d"></span>
            <span style="background:#7c5cd6"></span>
          </div>
          <span>Un site unique, monté en quelques minutes 💝</span>
        </div>
      </div>

      {hero && (
        <div class="phone">
          <div class="phone-screen">
            <iframe src={hero.url} title="Aperçu" loading="lazy" scrolling="no" tabindex="-1"></iframe>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="wrap feat">
    <div class="feat-head">
      <h2>Choisis ton ambiance 🎈</h2>
      <a class="more" href="/galerie">Voir tous les modèles →</a>
    </div>
    <div class="grid">
      {featured.map((t) => <Card t={t} />)}
    </div>
  </section>
</Base>

<style>
  .hero { position:relative; overflow:hidden; }
  .hero-in { display:flex; gap:44px; align-items:center; padding:52px 24px 60px; }
  .hero-text { flex:1; min-width:300px; }
  .hero h1 { font-size:clamp(38px,5.4vw,60px); line-height:1.02; letter-spacing:-.02em; margin:18px 0 0; font-weight:800; }
  .hero .hl { color:var(--coral); }
  .lead { font-size:18px; line-height:1.6; color:var(--muted); margin:20px 0 0; max-width:460px; }
  .cta { display:flex; gap:14px; margin-top:30px; flex-wrap:wrap; }
  .proof { display:flex; align-items:center; gap:14px; margin-top:34px; color:var(--muted); font-weight:600; font-size:13px; }
  .avatars { display:flex; }
  .avatars span { width:34px; height:34px; border-radius:50%; border:2px solid var(--cream); margin-left:-12px; }
  .avatars span:first-child { margin-left:0; }

  .phone { flex:none; }
  .phone-screen { width:270px; height:548px; border-radius:40px; background:#fff; border:1px solid var(--line); box-shadow:0 36px 80px rgba(120,90,60,.2); padding:10px; transform:rotate(2deg); }
  .phone-screen iframe { width:100%; height:100%; border:0; border-radius:30px; background:#0a1430; }

  /* Confetti */
  .confetti { position:absolute; pointer-events:none; }
  .c1 { top:96px; left:42px; width:14px; height:14px; border-radius:4px; background:var(--coral); transform:rotate(20deg); }
  .c2 { top:150px; left:33%; width:11px; height:11px; border-radius:50%; background:var(--blue); }
  .c3 { top:60px; left:54%; width:10px; height:22px; border-radius:5px; background:var(--gold); transform:rotate(-18deg); }
  .c4 { top:230px; left:90px; width:10px; height:10px; border-radius:50%; background:var(--green); }
  .c5 { bottom:60px; left:24%; width:12px; height:12px; border-radius:4px; background:var(--purple); transform:rotate(34deg); }
  .c6 { top:120px; right:8%; width:12px; height:12px; border-radius:50%; background:var(--coral); }

  .feat { padding-top:14px; }
  .feat-head { display:flex; align-items:baseline; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:18px; }
  .feat-head h2 { font-size:28px; font-weight:800; margin:0; }
  .more { color:var(--coral); font-weight:800; font-size:14px; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px,1fr)); gap:18px; }

  @media (max-width:820px) {
    .hero-in { flex-direction:column-reverse; align-items:flex-start; }
    .phone { align-self:center; }
  }
</style>
