---
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, localizePath, t } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const c = t[lang].create;
---

<Base title={c.title} description={c.description} active="create">
  <section class="wrap composer">
    <div class="left">
      <span class="pill coral">{c.pill}</span>
      <h1>{c.h1}</h1>
      <p class="lead">{c.lead}</p>

      <div class="box">
        <textarea id="prompt" rows="4" placeholder={c.placeholder}></textarea>
        <div class="box-foot">
          <div class="chipset">
            <span class="mini">{c.miniPhotos}</span>
            <span class="mini">{c.miniMusic}</span>
          </div>
          <button
            class="btn primary"
            id="gen"
            data-label={c.gen}
            data-loading={c.generating}
            data-error={c.errorGeneric}>{c.gen}</button
          >
        </div>
      </div>

      <div class="lbl">{c.toneLabel}</div>
      <div class="tags" data-group="tone">
        {c.tones.map((tone, i) => <button class={i === 0 ? 'tag on' : 'tag'}>{tone}</button>)}
      </div>

      <div class="duo">
        <label class="field"
          ><span>{c.occasionLabel}</span>
          <select>
            {c.occasions.map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label class="field"
          ><span>{c.languageLabel}</span>
          <select><option>Français</option><option>English</option></select>
        </label>
      </div>

      <p id="note" class="note" hidden></p>
    </div>

    <aside class="aside card">
      <div class="aside-h">{c.asideTitle}</div>
      <ul>
        {c.asideSteps.map((s) => <li>{s}</li>)}
      </ul>
      <a class="btn ghost" href={localizePath('/galerie', lang)}>{c.asideBtn}</a>
      <p class="aside-note">{c.asideNote}</p>
    </aside>
  </section>
</Base>

<script>
  document.querySelectorAll('.tags').forEach((g) => {
    const tags = Array.from(g.querySelectorAll('.tag'));
    tags.forEach((t) =>
      t.addEventListener('click', () => {
        tags.forEach((x) => x.classList.remove('on'));
        t.classList.add('on');
      }),
    );
  });

  const note = document.getElementById('note') as HTMLElement | null;
  const genBtn = document.getElementById('gen') as HTMLButtonElement | null;
  const LABEL = genBtn?.dataset.label || 'Générer le site →';
  const LOADING = genBtn?.dataset.loading || 'Génération…';
  const ERR_GENERIC = genBtn?.dataset.error || 'Erreur lors de la génération.';

  genBtn?.addEventListener('click', async () => {
    const promptEl = document.getElementById('prompt') as HTMLTextAreaElement | null;
    const prompt = (promptEl?.value || '').trim();
    if (!prompt) {
      promptEl?.focus();
      return;
    }

    const tone = document.querySelector('.tags[data-group="tone"] .tag.on')?.textContent || '';
    const selects = document.querySelectorAll<HTMLSelectElement>('.duo select');
    const occasion = selects[0]?.value || '';
    const langue = selects[1]?.value || 'Français';

    if (genBtn) {
      genBtn.disabled = true;
      genBtn.textContent = LOADING;
    }
    if (note) note.hidden = true;

    try {
      const res = await fetch('/api/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, tone, occasion, langue }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || ERR_GENERIC);
      sessionStorage.setItem('confeti_ai_content', JSON.stringify(data));
      window.location.href = '/create/romantic-scroll/';
    } catch (err) {
      const msg = err instanceof Error ? err.message : ERR_GENERIC;
      if (note) {
        note.textContent = '❌ ' + msg;
        note.hidden = false;
        note.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      if (genBtn) {
        genBtn.disabled = false;
        genBtn.textContent = LABEL;
      }
    }
  });
</script>

<style>
  .composer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 30px;
    padding: 36px 24px 20px;
    align-items: start;
  }
  .left h1 {
    font-size: clamp(32px, 4.6vw, 46px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 16px 0 0;
  }
  .lead {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.6;
    margin: 12px 0 0;
    max-width: 480px;
  }
  .box {
    margin-top: 22px;
    border-radius: 16px;
    background: var(--surface);
    border: 1.5px solid var(--line);
    padding: 16px;
    box-shadow: var(--shadow);
  }
  .box textarea {
    width: 100%;
    border: 0;
    resize: vertical;
    font: inherit;
    font-size: 15px;
    color: var(--ink);
    background: transparent;
  }
  .box textarea:focus {
    outline: none;
  }
  .box-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .chipset {
    display: flex;
    gap: 8px;
  }
  .mini {
    padding: 8px 14px;
    border-radius: 8px;
    background: var(--cream);
    border: 1.5px solid var(--line);
    font-weight: 700;
    font-size: 12px;
    color: var(--muted);
  }
  .lbl {
    margin-top: 22px;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 10px;
  }
  .tag {
    padding: 9px 16px;
    border-radius: 999px;
    border: 1.5px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
  }
  .tag.on {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }
  .duo {
    display: flex;
    gap: 12px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .field {
    flex: 1;
    min-width: 160px;
  }
  .field span {
    display: block;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 6px;
  }
  .field select {
    width: 100%;
    padding: 11px 13px;
    border-radius: 10px;
    border: 1.5px solid var(--line);
    background: var(--surface);
    font: inherit;
    font-weight: 700;
    font-size: 14px;
    color: var(--ink);
  }
  .note {
    margin-top: 20px;
    padding: 14px 16px;
    border-radius: 12px;
    background: var(--coral-soft);
    color: var(--coral-d);
    font-weight: 600;
    font-size: 14px;
  }
  .note a {
    color: var(--coral-d);
    font-weight: 800;
    text-decoration: underline;
  }

  .aside {
    padding: 22px;
  }
  .aside-h {
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .aside ul {
    list-style: none;
    padding: 0;
    margin: 14px 0 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.4;
  }
  .aside .btn {
    width: 100%;
  }
  .aside-note {
    color: var(--faint);
    font-size: 12px;
    text-align: center;
    margin: 12px 0 0;
  }

  @media (max-width: 820px) {
    .composer {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1280px) {
    .composer {
      max-width: none;
      padding-left: 32px;
      padding-right: 32px;
      grid-template-columns: minmax(0, 1fr) 420px;
      gap: 60px;
    }
    .lead {
      max-width: none;
    }
  }
</style>
