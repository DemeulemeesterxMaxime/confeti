---
import Base from '../../layouts/Base.astro';
import Card from '../Card.astro';
import { getTemplates } from '../../lib/templates.js';
import { getLangFromUrl, t } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const h = t[lang].home;

const templates = getTemplates();
const featured = templates.slice(0, 3);
const hero = templates[0];

const jsonLd = {
  '@type': 'FAQPage',
  mainEntity: h.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title={h.title} description={h.description} jsonLd={jsonLd}>
  <section class="hero">
    <span class="Confeti c1"></span><span class="Confeti c2"></span><span class="Confeti c3"></span>
    <span class="Confeti c4"></span><span class="Confeti c5"></span><span class="Confeti c6"></span>
    <div class="wrap hero-in">
      <div class="hero-text">
        <span class="pill coral">{h.heroPill}</span>
        <h1 set:html={h.heroTitle} />
        <p class="lead">{h.heroLead}</p>
        <div class="cta">
          <a class="btn primary" href={lang === 'fr' ? '/galerie' : '/en/galerie'}>{h.ctaGallery}</a
          >
          <a class="btn ghost" href={lang === 'fr' ? '/create' : '/en/create'}>{h.ctaAi}</a>
        </div>
        <div class="proof">
          <div class="avatars">
            <span style="background:#3d9be0"></span>
            <span style="background:#2bb38a"></span>
            <span style="background:#f5b13d"></span>
            <span style="background:#7c5cd6"></span>
          </div>
          <span>{h.proof}</span>
        </div>
      </div>

      {
        hero && (
          <div class="phone">
            <div class="phone-screen">
              <iframe src={hero.url} title="Aperçu" loading="eager" scrolling="no" tabindex="-1" />
            </div>
          </div>
        )
      }
    </div>
  </section>

  <section class="wrap feat">
    <div class="feat-head">
      <h2>{h.featTitle}</h2>
      <a class="more" href={lang === 'fr' ? '/galerie' : '/en/galerie'}>{h.featMore}</a>
    </div>
    <div class="grid">
      {featured.map((tpl) => <Card t={tpl} />)}
    </div>
  </section>

  <section class="wrap faq">
    <h2>{h.faqTitle}</h2>
    <div class="faq-list">
      {
        h.faqs.map((f) => (
          <details class="faq-item card">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }
  .hero-in {
    display: flex;
    gap: 44px;
    align-items: center;
    padding: 52px 24px 60px;
  }
  .hero-text {
    flex: 1;
    min-width: 300px;
  }
  .hero h1 {
    font-size: clamp(38px, 5.4vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 18px 0 0;
    font-weight: 800;
  }
  .hero .hl {
    color: var(--coral);
  }
  .lead {
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    margin: 20px 0 0;
    max-width: 460px;
  }
  .cta {
    display: flex;
    gap: 14px;
    margin-top: 30px;
    flex-wrap: wrap;
  }
  .proof {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 34px;
    color: var(--muted);
    font-weight: 600;
    font-size: 13px;
  }
  .avatars {
    display: flex;
  }
  .avatars span {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid var(--cream);
    margin-left: -12px;
  }
  .avatars span:first-child {
    margin-left: 0;
  }

  .phone {
    flex: none;
  }
  .phone-screen {
    width: 270px;
    height: 548px;
    border-radius: 40px;
    background: #fff;
    border: 1px solid var(--line);
    box-shadow: 0 36px 80px rgba(120, 90, 60, 0.2);
    padding: 10px;
    transform: rotate(2deg);
  }
  .phone-screen iframe {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 30px;
    background: #0a1430;
  }

  /* Confeti */
  .Confeti {
    position: absolute;
    pointer-events: none;
  }
  .c1 {
    top: 96px;
    left: 42px;
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--coral);
    transform: rotate(20deg);
  }
  .c2 {
    top: 150px;
    left: 33%;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--blue);
  }
  .c3 {
    top: 60px;
    left: 54%;
    width: 10px;
    height: 22px;
    border-radius: 5px;
    background: var(--gold);
    transform: rotate(-18deg);
  }
  .c4 {
    top: 230px;
    left: 90px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--green);
  }
  .c5 {
    bottom: 60px;
    left: 24%;
    width: 12px;
    height: 12px;
    border-radius: 4px;
    background: var(--purple);
    transform: rotate(34deg);
  }
  .c6 {
    top: 120px;
    right: 8%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--coral);
  }

  .feat {
    padding-top: 14px;
  }
  .feat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .feat-head h2 {
    font-size: 28px;
    font-weight: 800;
    margin: 0;
  }
  .more {
    color: var(--coral);
    font-weight: 800;
    font-size: 14px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
  }

  .faq {
    padding-top: 56px;
    padding-bottom: 20px;
    max-width: 760px;
  }
  .faq h2 {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 18px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    padding: 4px 20px;
  }
  .faq-item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 800;
    font-size: 16px;
    padding: 16px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    color: var(--coral);
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-item p {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .hero-in {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
    .phone {
      align-self: center;
    }
  }
</style>
